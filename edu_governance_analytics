def apply_custom_style(ax, title, xlabel, ylabel):
    ax.set_title(title, fontsize=22, fontweight='bold', fontname='Times New Roman', pad=15)
    ax.set_xlabel(xlabel, fontsize=20, fontweight='bold', fontname='Times New Roman')
    ax.set_ylabel(ylabel, fontsize=20, fontweight='bold', fontname='Times New Roman')
    ax.tick_params(axis='x', labelsize=18)
    ax.tick_params(axis='y', labelsize=18)
    for label in ax.get_xticklabels() + ax.get_yticklabels():
        label.set_fontname('Times New Roman')
        label.set_fontweight('bold')
    if ax.get_legend():
        plt.setp(ax.get_legend().get_texts(), fontsize=16, fontname='Times New Roman', fontweight='bold')
    ax.grid(False)

def add_values_on_bars(ax):
